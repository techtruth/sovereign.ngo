{
  "actionTemplates": {
    "schedule_appointment": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "RadiologyAppointmentRequestCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging"
      },
      "subjectFromPayload": {
        "requestedDate": "requestedDate",
        "modality": "modality",
        "reason": "reason"
      },
      "includePayload": true
    },
    "walk_in_check_in": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "RadiologyWalkInCheckInCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging"
      },
      "subjectFromPayload": {
        "arrivalMode": "arrivalMode",
        "arrivalNote": "arrivalNote"
      },
      "includePayload": true
    },
    "request_xray": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "RadiologyXRayRequestCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging",
        "modality": "xray"
      },
      "subjectFromPayload": {
        "studyReason": "studyReason",
        "bodyRegion": "bodyRegion",
        "priority": "priority"
      },
      "includePayload": true
    },
    "request_ultrasound": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "RadiologyUltrasoundRequestCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging",
        "modality": "ultrasound"
      },
      "subjectFromPayload": {
        "studyReason": "studyReason",
        "bodyRegion": "bodyRegion",
        "priority": "priority"
      },
      "includePayload": true
    },
    "confirm_radiology_appointment": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "RadiologyAppointmentConfirmationCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging"
      },
      "subjectFromPayload": {
        "referralRecordId": "referralRecordId",
        "referralRecordType": "referralRecordType",
        "scheduledAt": "scheduledAt",
        "facility": "facility",
        "room": "room",
        "modality": "modality"
      },
      "verificationDependencies": [
        { "credentialType": "ExternalMedicalRecordLinkCredential", "policy": "required" }
      ],
      "includePayload": true
    },
    "issue_xray_result": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "XRayImagingResultCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging",
        "modality": "xray"
      },
      "subjectFromPayload": {
        "referralRecordId": "referralRecordId",
        "referralRecordType": "referralRecordType",
        "studyId": "studyId",
        "performedAt": "performedAt",
        "resultSummary": "resultSummary"
      },
      "verificationDependencies": [
        { "credentialType": "ExternalMedicalRecordLinkCredential", "policy": "required" }
      ],
      "includePayload": true
    },
    "issue_ultrasound_result": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "UltrasoundImagingResultCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Riverstone Radiology Center",
        "serviceDomain": "radiology-imaging",
        "modality": "ultrasound"
      },
      "subjectFromPayload": {
        "referralRecordId": "referralRecordId",
        "referralRecordType": "referralRecordType",
        "studyId": "studyId",
        "performedAt": "performedAt",
        "resultSummary": "resultSummary"
      },
      "verificationDependencies": [
        { "credentialType": "ExternalMedicalRecordLinkCredential", "policy": "required" }
      ],
      "includePayload": true
    }
  }
}
