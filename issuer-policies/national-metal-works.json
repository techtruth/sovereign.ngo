{
  "actionTemplates": {
    "issue_vendor_approval": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "VendorApprovalCredential"],
      "storage": "issuer",
      "subjectDefaults": {
        "company": "Buffalo Mountain Metal Works",
        "complianceDomain": "vendor_management"
      },
      "subjectFromPayload": {
        "vendorName": "vendorName",
        "vendorId": "vendorId"
      },
      "includePayload": true
    },
    "issue_shipment_provenance": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "ShipmentProvenanceCredential"],
      "storage": "issuer",
      "subjectDefaults": {
        "company": "Buffalo Mountain Metal Works",
        "complianceDomain": "logistics"
      },
      "subjectFromPayload": {
        "shipmentId": "shipmentId",
        "lotId": "lotId"
      },
      "includePayload": true
    },
    "issue_material_certificate": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "MaterialCertificateCredential"],
      "storage": "issuer",
      "subjectDefaults": {
        "company": "Buffalo Mountain Metal Works",
        "complianceDomain": "materials"
      },
      "subjectFromPayload": {
        "materialCode": "materialCode",
        "grade": "grade"
      },
      "includePayload": true
    }
  }
}
