{
  "actionTemplates": {
    "issue_policy_verification": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "InsurancePolicyVerificationCredential"],
      "storage": "issuer",
      "subjectDefaults": {
        "issuerCompany": "Apple Seed Insurance",
        "coverageRegion": "TN"
      },
      "subjectFromPayload": {
        "policyNumber": "policyNumber",
        "policyStatus": "policyStatus",
        "coverageType": "coverageType"
      },
      "includePayload": true
    },
    "issue_claim_intake_receipt": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "ClaimIntakeReceiptCredential"],
      "storage": "issuer",
      "subjectDefaults": {
        "issuerCompany": "Apple Seed Insurance",
        "claimStatus": "received"
      },
      "subjectFromPayload": {
        "claimId": "claimId",
        "policyNumber": "policyNumber",
        "incidentDate": "incidentDate"
      },
      "includePayload": true
    },
    "issue_benefit_eligibility": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "InsuranceBenefitEligibilityCredential"],
      "storage": "issuer",
      "subjectDefaults": {
        "issuerCompany": "Apple Seed Insurance"
      },
      "subjectFromPayload": {
        "policyNumber": "policyNumber",
        "benefitStatus": "benefitStatus",
        "benefitType": "benefitType"
      },
      "includePayload": true
    }
  }
}
