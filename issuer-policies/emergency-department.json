{
  "actionTemplates": {
    "confirm_er_intake": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "EmergencyIntakeCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Summitview Emergency Department",
        "serviceDomain": "emergency-care"
      },
      "subjectFromPayload": {
        "arrivalMode": "arrivalMode",
        "acuityLevel": "acuityLevel",
        "triageStartedAt": "triageStartedAt"
      },
      "includePayload": true
    },
    "issue_er_disposition": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "EmergencyDispositionCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Summitview Emergency Department",
        "serviceDomain": "emergency-care"
      },
      "subjectFromPayload": {
        "disposition": "disposition",
        "dispositionAt": "dispositionAt",
        "destination": "destination"
      },
      "includePayload": true
    },
    "issue_er_discharge_summary": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "EmergencyDischargeSummaryCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "issuerOrganization": "Summitview Emergency Department",
        "serviceDomain": "emergency-care"
      },
      "subjectFromPayload": {
        "dischargeAt": "dischargeAt",
        "followUpPlan": "followUpPlan",
        "dischargeInstructions": "dischargeInstructions"
      },
      "includePayload": true
    }
  }
}
