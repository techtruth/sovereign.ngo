{
  "actionTemplates": {
    "issue_service_record": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "AutoServiceRecordCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "serviceDomain": "auto_repair"
      },
      "subjectFromPayload": {
        "vehicleVin": "vehicleVin",
        "serviceCategory": "serviceCategory"
      },
      "includePayload": true
    },
    "issue_safety_inspection": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "SafetyInspectionCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "inspectionDomain": "motor_vehicle"
      },
      "subjectFromPayload": {
        "vehicleVin": "vehicleVin",
        "inspectionResult": "inspectionResult"
      },
      "includePayload": true
    },
    "create_repair_estimate": {
      "context": ["https://www.w3.org/ns/credentials/v2"],
      "types": ["VerifiableCredential", "RepairEstimateCredential"],
      "storage": "sovereign",
      "subjectDefaults": {
        "estimateDomain": "auto_repair"
      },
      "subjectFromPayload": {
        "vehicleVin": "vehicleVin",
        "estimatedAmount": "estimatedAmount"
      },
      "includePayload": true
    }
  }
}
