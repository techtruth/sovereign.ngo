FROM node:20-alpine

WORKDIR /app

COPY verifier-sites/verifier-portal-api-server.js ./verifier-portal-api-server.js

ENV PORT=5000
ENV VERIFIER_PROFILE=drivers_license
ENV VERIFIER_NAME="Drivers License Verifier"
ENV VERIFIER_DID=did:example:verifier:drivers-license
ENV SIGNING_SECRET=change-me

EXPOSE 5000

CMD ["node", "verifier-portal-api-server.js"]
